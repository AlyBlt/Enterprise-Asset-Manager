@model AssetManager.Web.Models.User.UserListViewModel

@{
    ViewData["Title"] = "User Management";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-people-fill text-success me-2"></i>User Management
            </h2>
            <p class="text-muted small mb-0">Manage system access, roles, and personnel data.</p>
        </div>

        @if (ViewBag.SelectedDepartmentId != null)
        {
            <a asp-action="Users" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                <i class="bi bi-x-circle me-1"></i> Clear Filter
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold">User</th>
                        <th class="py-3 text-uppercase small fw-bold">Department</th>
                        <th class="py-3 text-uppercase small fw-bold">Current Role</th>
                        <th class="py-3 text-uppercase small fw-bold text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="bg-success bg-opacity-10 text-success rounded-circle p-2 me-3">
                                        <i class="bi bi-person fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@user.FullName</div>
                                        <div class="text-muted small">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-white text-dark border px-3 py-2 rounded-pill">
                                    <i class="bi bi-building me-1 text-success"></i> @(user.DepartmentName ?? "Unassigned")
                                </span>
                            </td>
                            <td>
                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary") rounded-pill px-3">
                                    @user.Role
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <button class="btn btn-light btn-sm rounded-circle shadow-sm me-2"
                                            data-bs-toggle="modal"
                                            data-bs-target="#roleModal-@user.Id"
                                            title="Change Role">
                                        <i class="bi bi-shield-lock text-primary"></i>
                                    </button>
                                    <button class="btn btn-light btn-sm rounded-circle shadow-sm"
                                            onclick="confirmDeleteUser(@user.Id, '@user.Username')"
                                            title="Delete User">
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </div>

                                <div class="modal fade" id="roleModal-@user.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-sm modal-dialog-centered">
                                        <div class="modal-content border-0 shadow rounded-4 text-start">
                                            <form asp-action="ChangeRole" method="post">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <div class="modal-body p-4">
                                                    <h6 class="fw-bold mb-3">Update Role for @user.Username</h6>
                                                    <select name="newRole" class="form-select rounded-3">
                                                        <option value="3" selected="@(user.Role == "Guest")">Guest</option>
                                                        <option value="2" selected="@(user.Role == "Editor")">Editor</option>
                                                        <option value="1" selected="@(user.Role == "Admin")">Admin</option>
                                                    </select>
                                                </div>
                                                <div class="modal-footer border-0 p-4 pt-0">
                                                    <button type="button" class="btn btn-light rounded-pill px-3" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-success rounded-pill px-4">Save</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDeleteUser(id, name) {
            Swal.fire({
                title: 'Are you sure?',
                text: `You are about to delete user "${name}". This action is reversible via database but will revoke access!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#ef4444',
                confirmButtonText: 'Yes, delete it!',
                border: 'none',
                borderRadius: '15px'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '/Admin/DeleteUser';
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'userId';
                    input.value = id;
                    form.appendChild(input);
                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
    </script>
}