@model AssetManager.Web.Models.User.UserListViewModel

@{
    ViewData["Title"] = "User Management";
}

<div class="container py-5 animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-people-fill text-success me-2"></i>User Management
            </h2>
            <p class="text-muted small mb-0">Manage system access, roles, and personnel data.</p>
        </div>

        @if (ViewBag.SelectedDepartmentId != null)
        {
            <a asp-action="Users" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                <i class="bi bi-x-circle me-1"></i> Clear Filter
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 text-uppercase small fw-bold">User</th>
                        <th class="py-3 text-uppercase small fw-bold">Department</th>
                        <th class="py-3 text-uppercase small fw-bold">Current Role</th>
                        <th class="py-3 text-uppercase small fw-bold text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="bg-success bg-opacity-10 text-success rounded-circle p-2 me-3">
                                        <i class="bi bi-person fs-5"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@user.FullName</div>
                                        <div class="text-muted small">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-white text-dark border px-3 py-2 rounded-pill">
                                    <i class="bi bi-building me-1 text-success"></i> @(user.DepartmentName ?? "Unassigned")
                                </span>
                            </td>
                            <td>
                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary") rounded-pill px-3">
                                    @user.Role
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <button class="btn btn-light btn-sm rounded-circle shadow-sm me-2"
                                            data-bs-toggle="modal"
                                            data-bs-target="#roleModal-@user.Id"
                                            title="Change Role & Department">
                                        <i class="bi bi-shield-lock text-primary"></i>
                                    </button>
                                    <button class="btn btn-light btn-sm rounded-circle shadow-sm"
                                            onclick="confirmDeleteUser(@user.Id, '@user.Username')"
                                            title="Delete User">
                                        <i class="bi bi-trash text-danger"></i>
                                    </button>
                                </div>

                                @* Role & Department Modal *@
                                <div class="modal fade" id="roleModal-@user.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content border-0 shadow-lg rounded-4">
                                            <div class="modal-header border-0 pb-0 pt-4 px-4">
                                                <h5 class="fw-bold mb-0">Update Personnel: @user.FullName</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <form asp-action="UpdateUserAccess" method="post">
                                                @* Action adını güncelledik *@
                                                <input type="hidden" name="userId" value="@user.Id" />

                                                <div class="modal-body p-4">
                                                    @* Departman Seçimi *@
                                                    <div class="mb-3">
                                                        <label class="form-label small fw-bold text-muted text-uppercase">Organizational Unit (Department)</label>
                                                        <div class="input-group">
                                                            <span class="input-group-text bg-light border-0"><i class="bi bi-building text-success"></i></span>
                                                            <select name="departmentId" class="form-select bg-light border-0 shadow-none">
                                                                <option value="">-- No Department --</option>
                                                                @foreach (var dept in Model.Departments)
                                                                {
                                                                    <option value="@dept.Id" selected="@(user.DepartmentId == dept.Id)">
                                                                        @dept.Name
                                                                    </option>
                                                                }
                                                            </select>
                                                        </div>
                                                    </div>

                                                    @* Rol Seçimi *@
                                                    <div class="mb-2">
                                                        <label class="form-label small fw-bold text-muted text-uppercase">Security Role</label>
                                                        <div class="input-group">
                                                            <span class="input-group-text bg-light border-0"><i class="bi bi-shield-lock text-success"></i></span>
                                                            <select name="newRole" class="form-select bg-light border-0 shadow-none">
                                                                <option value="Guest" selected="@(user.Role == "Guest")">Guest (View Only)</option>
                                                                <option value="Editor" selected="@(user.Role == "Editor")">Editor (Manage Assets)</option>
                                                                <option value="Admin" selected="@(user.Role == "Admin")">Admin (System Manager)</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <p class="text-muted mt-3 mb-0" style="font-size: 0.75rem;">
                                                        <i class="bi bi-info-circle me-1"></i> Changes will take effect on the user's next action or login.
                                                    </p>
                                                </div>

                                                <div class="modal-footer border-0 p-4 pt-0 d-grid gap-2">
                                                    <button type="submit" class="btn btn-success rounded-pill py-2 shadow-sm">
                                                        <i class="bi bi-cloud-upload me-2"></i>Save Management Changes
                                                    </button>
                                                    <button type="button" class="btn btn-light rounded-pill py-2" data-bs-dismiss="modal">Cancel</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDeleteUser(id, name) {
            Swal.fire({
                title: 'Are you sure?',
                text: `You are about to delete user "${name}". This action is reversible via database but will revoke access!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#10b981',
                confirmButtonText: 'Delete',
                border: 'none',
                borderRadius: '15px'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '/Admin/DeleteUser';
                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'userId';
                    input.value = id;
                    form.appendChild(input);
                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }
    </script>
}