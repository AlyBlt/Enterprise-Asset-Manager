@using AssetManager.Core.Enums
@model AssetManager.Application.DTOs.Asset.AssetResponseDto

@{
    ViewData["Title"] = "Asset Details - " + Model.Name;
}

<div class="container animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">@Model.Name</h2>
            <span class="badge bg-light text-secondary border px-3 mt-2">Serial: @Model.SerialNumber</span>
        </div>
        <a asp-action="Index" class="btn btn-white btn-lg rounded-circle shadow-sm me-3">
            <i class="bi bi-arrow-left text-success"></i>Back
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">General Information</h5>

                    <div class="mb-3">
                        <label class="text-muted small d-block">Current Status</label>
                        @{
                            // Hata buradaydı: String tırnaklarını kaldırıp Enum tipini kullanıyoruz
                            var statusClass = Model.Status switch
                            {
                                AssetStatus.Assigned => "text-primary",
                                AssetStatus.InStock => "text-success",
                                AssetStatus.Lost => "text-danger",
                                AssetStatus.InRepair => "text-warning",
                                _ => "text-info"
                            };
                        }
                        <span class="fw-bold @statusClass">
                            <i class="bi bi-circle-fill me-1 small"></i> @Model.Status
                        </span>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small d-block">Category</label>
                        <span class="fw-semibold text-dark">@Model.Category</span>
                    </div>

                    <div class="mb-3">
                        <label class="text-muted small d-block">Purchase Price</label>
                        <span class="fw-bold text-success fs-5">$ @Model.Price.ToString("N2", System.Globalization.CultureInfo.GetCultureInfo("en-US"))</span>
                    </div>

                    <hr class="text-muted opacity-25" />

                    <div class="mb-1">
                        <label class="text-muted small d-block">Description</label>
                        <p class="text-dark small lh-base">
                            @(string.IsNullOrEmpty(Model.Description) ? "No description provided for this asset." : Model.Description)
                        </p>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.AssignedUserName))
            {
                <div class="card border-0 shadow-sm rounded-4 bg-primary bg-opacity-10 border-start border-primary border-4">
                    <div class="card-body p-4">
                        <h6 class="fw-bold text-primary mb-3">
                            <i class="bi bi-person-badge-fill me-2"></i>Current Custodian
                        </h6>
                        <div class="d-flex align-items-center">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width:45px; height:45px;">
                                <i class="bi bi-person fs-4"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">@Model.AssignedUserName</div>
                                <small class="text-muted">Responsible Personnel</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm rounded-4 bg-light">
                    <div class="card-body p-4 text-center">
                        <i class="bi bi-house-door text-muted fs-2 mb-2"></i>
                        <p class="text-muted small mb-0">This asset is currently <strong>In Stock</strong> and not assigned to anyone.</p>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Asset Life Cycle</h5>
                    <div class="timeline mt-4">
                        <div class="timeline-item pb-4 border-start ps-4 position-relative ml-2">
                            <i class="bi bi-plus-circle-fill position-absolute text-success" style="left: -11px; top: 0; background: white; font-size: 1.2rem;"></i>
                            <div class="small text-muted fw-medium">System Registry</div>
                            <div class="fw-bold text-dark">Asset created and serialized</div>
                            <div class="text-muted small mt-1">Status: Initial Entry</div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.AssignedUserName))
                        {
                            <div class="timeline-item pb-4 border-start ps-4 position-relative ml-2">
                                <i class="bi bi-arrow-right-circle-fill position-absolute text-primary" style="left: -11px; top: 0; background: white; font-size: 1.2rem;"></i>
                                <div class="small text-muted fw-medium">Handover Completed</div>
                                <div class="fw-bold text-dark">Assigned to @Model.AssignedUserName</div>
                                <div class="text-muted small mt-1">Personnel has acknowledged receipt of the asset.</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .timeline-item:last-child {
        border-start: 0 !important;
    }

    .timeline {
        margin-left: 10px;
    }
</style>