@model AssetManager.Web.Models.Asset.AssetListViewModel

@{
    ViewData["Title"] = Model.PageTitle;
}

<div class="container-fluid animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">@Model.PageTitle</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index" class="text-success text-decoration-none">Dashboard</a></li>
                    <li class="breadcrumb-item active">Inventory</li>
                </ol>
            </nav>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>Add New Asset
            </a>
        }
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light border-bottom">
                        <tr>
                            <th class="ps-4 py-3 text-muted fw-semibold">ASSET NAME</th>
                            <th class="py-3 text-muted fw-semibold">SERIAL NUMBER</th>
                            <th class="py-3 text-muted fw-semibold">CATEGORY</th>
                            <th class="py-3 text-muted fw-semibold">VALUE</th>
                            <th class="py-3 text-muted fw-semibold">STATUS</th>
                            <th class="pe-4 py-3 text-end text-muted fw-semibold">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var asset in Model.Assets)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-success bg-opacity-10 p-2 rounded-3 me-3 text-success">
                                            <i class="bi bi-pc-display fs-5"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@asset.Name</div>
                                            <small class="text-muted">ID: #@asset.Id</small>
                                        </div>
                                    </div>
                                </td>
                                <td><code class="text-secondary fw-medium">@asset.SerialNumber</code></td>
                                <td><span class="badge bg-light text-dark border fw-medium px-3 py-2 rounded-pill">@asset.Category</span></td>
                                <td class="fw-bold">@asset.Price.ToString("C2", new System.Globalization.CultureInfo("en-US"))</td>
                                <td>
                                    @{
                                        var statusClass = asset.Status.ToString() switch
                                        {
                                            "Assigned" => "bg-primary",
                                            "InStock" => "bg-success",
                                            "Lost" => "bg-danger",
                                            "InRepair" => "bg-warning text-dark",
                                            "Retired" => "bg-secondary",
                                            _ => "bg-info"
                                        };
                                    }
                                    <span class="badge @statusClass px-3 py-2 rounded-pill shadow-sm" style="min-width: 90px;">
                                        <i class="bi bi-circle-fill me-1 small"></i> @asset.Status
                                    </span>
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                        <a asp-action="Details" asp-route-id="@asset.Id" class="btn btn-white btn-sm px-3 border-end" title="View Details">
                                            <i class="bi bi-eye text-primary"></i>
                                        </a>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form asp-action="Delete" asp-route-id="@asset.Id" method="post"
                                                  onsubmit="return confirm('Are you sure you want to delete this asset?');"
                                                  class="d-inline">
                                                <button type="submit" class="btn btn-white btn-sm px-3" title="Delete">
                                                    <i class="bi bi-trash3 text-danger"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(16, 185, 129, 0.02);
    }

    .btn-white {
        background-color: #fff;
        border: 1px solid #edf2f7;
    }

        .btn-white:hover {
            background-color: #f8fafc;
        }
</style>