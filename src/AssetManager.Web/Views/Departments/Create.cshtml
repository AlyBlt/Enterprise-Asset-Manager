@model AssetManager.Web.Models.Department.DepartmentCreateViewModel

@{
    ViewData["Title"] = "Create Department";
}

<div class="container animate__animated animate__fadeIn py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="d-flex align-items-center mb-4">
                <a asp-action="Index" class="btn btn-light rounded-circle me-3 shadow-sm">
                    <i class="bi bi-arrow-left text-success"></i>
                </a>
                <div>
                <h2 class="fw-bold text-dark mb-0">Add New Department</h2>
                <p class="text-muted small mb-0">Enter the required information to create the new department.</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-success bg-opacity-10 py-3 border-0">
                    <h6 class="mb-0 text-success fw-bold"><i class="bi bi-pencil-square me-2"></i>Department Information</h6>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-semibold text-muted small text-uppercase"></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-building text-success"></i></span>
                                <input asp-for="Name" class="form-control border-0 bg-light p-3" placeholder="e.g. IT Department" />
                            </div>
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold text-muted small text-uppercase"></label>
                            <textarea asp-for="Description" class="form-control border-0 bg-light p-3" rows="3" placeholder="Briefly describe the department's role..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mt-5 d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-light px-5 rounded-pill fw-semibold">Cancel</a>
                            <button type="submit" class="btn btn-success rounded-pill px-5 fw-bold shadow">
                               <i class="bi bi-check-circle me-2"></i>Create Department
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <p class="small text-muted">
                    <i class="bi bi-info-circle me-1"></i>
                    Departments are used to organize assets and personnel.
                </p>
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
  
    .form-control::placeholder {
        color: #6b7280; 
        opacity: 0.5;
    }
</style>
}