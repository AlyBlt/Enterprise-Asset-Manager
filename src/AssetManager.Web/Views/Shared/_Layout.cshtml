<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AssetManager</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --primary-forest: #064e3b;
            --accent-emerald: #10b981;
            --hover-green: #34d399; 
            --bg-light: #f0fdf4;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-light);
        }

        .navbar {
            background-color: var(--primary-forest) !important;
            box-shadow: 0 2px 15px rgba(0,0,0,0.15);
            padding: 0.8rem 1rem;
        }

        .nav-link {
            font-weight: 500;
            color: rgba(255,255,255,0.8) !important; /* Normal hali hafif saydam beyaz */
            transition: all 0.25s ease-in-out;
            margin: 0 5px;
            position: relative;
        }

            /* Hover sırasında altına ince bir yeşil çizgi ekle */
            .nav-link::after {
                content: '';
                position: absolute;
                width: 0;
                height: 2px;
                bottom: 0;
                left: 0;
                background-color: var(--accent-emerald);
                transition: width 0.3s ease;
            }

            .nav-link:hover::after {
                width: 100%;
            }

            /* Aktif sayfa linki */
            .nav-link.active {
                color: var(--accent-emerald) !important;
                font-weight: 700;
            }

        .admin-link {
            color: #fbbf24 !important;
        }

            .admin-link:hover {
                color: #f59e0b !important;
                text-shadow: 0 0 8px rgba(251, 191, 36, 0.4) !important;
            }

        .main-container {
            min-height: 85vh;
            padding-top: 2.5rem;
        }

        .footer {
            background: white;
            border-top: 1px solid #d1fae5;
        }

        /* Kullanıcı butonu hover fix - Arka plan beyaz olduğunda yazı koyu yeşil olur */
        .navbar-nav .dropdown-toggle.btn-outline-light:hover,
        .navbar-nav .dropdown-toggle.btn-outline-light:focus,
        .navbar-nav .nav-item.dropdown.show > .btn-outline-light {
            background-color: #ffffff !important;
            color: var(--primary-forest) !important; /* Yazıyı koyu yeşil yap ki beyaz üzerinde görünsün */
            border-color: #ffffff !important;
        }

           
        /* Dropdown içindeki logout yazısının hover hali */
        .dropdown-item.text-danger:hover {
            background-color: #fee2e2 !important; /* Hafif kırmızı arka plan */
            color: #dc2626 !important;
        }

        /* Nav-link hover etkisinin bu butonda çizgili görünmesini engellemek için */
        .btn-outline-light.nav-link::after {
            display: none !important;
        }
       
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shield-check me-2 text-success"></i>
                    <span>Asset<span style="color: var(--accent-emerald)">Manager</span></span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-grid-1x2-fill me-1"></i> Dashboard
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Assets" asp-action="Index">
                                    <i class="bi bi-laptop me-1"></i> Assets
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Departments" asp-action="Index">
                                    <i class="bi bi-diagram-3 me-1"></i> Departments
                                </a>
                            </li>

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle admin-link" href="#" role="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-gear-fill me-1"></i> Admin Panel
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users"><i class="bi bi-people-fill me-2"></i>User Management</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Logs"><i class="bi bi-activity me-2"></i>System Logs</a></li>
                                    </ul>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav align-items-lg-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle btn btn-outline-light btn-sm px-3 text-white rounded-pill" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-fill me-1"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger fw-bold" asp-controller="Account" asp-action="Logout"><i class="bi bi-power me-2"></i>Logout</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-success btn-sm ms-lg-2 px-4 rounded-pill text-white" asp-controller="Account" asp-action="Register" style="background-color: var(--accent-emerald); border:none;">Get Started</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer py-4 mt-auto">
        <div class="container text-center">
            <div class="row align-items-center">
                <div class="col-md-6 text-md-start small">
                    <span class="fw-bold">AssetManager Enterprise</span> &copy; 2026 
                </div>
                <div class="col-md-6 text-md-end">
                    <span class="text-muted me-3 small">DevOps/FinalProject</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Styles", required: false)
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>